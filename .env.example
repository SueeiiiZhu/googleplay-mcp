# Google Service Account 认证 (二选一)
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# 默认包名 (可选)
GOOGLE_PLAY_PACKAGE_NAME=com.example.app

# GCS 报告 bucket (可选, 用于财务/销售报告下载)
GOOGLE_PLAY_REPORT_BUCKET=pubsite_prod_rev_00000000000000000000

# gsutil 二进制路径 (可选, 默认在 PATH 中查找 'gsutil')
# 当 Service Account 在 bucket 上没有 object 读权限 (403) 时, reports tools
# 会自动 fallback 到 gsutil, 使用本机 gcloud auth login 的用户凭证下载。
# 适合 Play Console 财务权限同步到 GCS IAM 失败的场景。
# GOOGLE_PLAY_GSUTIL_BIN=/usr/local/bin/gsutil
